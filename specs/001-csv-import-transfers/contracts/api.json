# contracts/api.json
{
  "openapi": "3.0.0",
  "info": {
    "title": "Bank CSV Import API",
    "version": "1.0.0"
  },
  "paths": {
    "/transfers/import": {
      "post": {
        "summary": "Import CSV file (API Platform custom operation)",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfers imported successfully"
          },
          "400": {
            "description": "Invalid CSV format or error"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "x-api-platform-operation": "Custom #[Post] operation on TransferImportDTO resource, handled by custom controller/DataTransformer"
      }
    },
    "/transfers": {
      "get": {
        "summary": "List transfers (DTO output)",
        "responses": {
          "200": {
            "description": "List of transfers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransferOutputDTO"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TransferImportDTO": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "amount": { "type": "number", "format": "decimal" },
          "currency": { "type": "string" },
          "from_account": { "type": "string" },
          "to_account": { "type": "string" },
          "reference": { "type": "string" },
          "transaction_id": { "type": "string" }
        },
        "required": ["date", "amount", "currency", "from_account", "to_account", "reference"]
      },
      "TransferOutputDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "amount": { "type": "number", "format": "decimal" },
          "currency": { "type": "string" },
          "from_account": { "type": "string" },
          "to_account": { "type": "string" },
          "reference": { "type": "string" },
          "labels": { "type": "array", "items": { "type": "string" } },
          "transaction_id": { "type": "string" }
        }
      }
    }
  }
}
